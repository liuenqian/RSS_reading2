{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RSS Reading",
  "version": "1.1.14",
  "identifier": "io.github.liuenqian.rssreading",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "RSS Reading",
        "width": 1200,
        "height": 750,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 20, "y": 20 }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app", "nsis", "appimage", "deb"],
    "resources": ["resources/nature-skills/nature-downloader/"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/256x256.png",
      "icons/512x512.png",
      "icons/512x512@2x.png",
      "icons/1024x1024.png",
      "icons/cento.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-"
    }
  }
}
